# ============================================================
# DebtWise - Environment Configuration
# Copy this file to .env and fill in the values
# ============================================================

# Application
APP_PORT=3000
NODE_ENV=production

# IMPORTANT: Change these before deploying!
# Generate a strong JWT secret: openssl rand -base64 64
JWT_SECRET=CHANGE_THIS_TO_A_VERY_LONG_RANDOM_SECRET_STRING_AT_LEAST_64_CHARS

# Token expiry: 24h, 7d, 30d
JWT_EXPIRES_IN=24h

# Frontend URL (used for CORS)
FRONTEND_URL=http://localhost:3000

# Data persistence path (host directory for SQLite database)
DATA_PATH=./data

# Logging
LOG_LEVEL=info
